    "eslint-config-standard-with-typescript": "20.0.0",
    "eslint-plugin-import": "2.23.4",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-prettier": "3.4.0",
    "eslint-plugin-promise": "5.1.0",
    "husky": "6.0.0",
    "jest": "27.0.5",
    "lint-staged": "11.0.0",
    "markdownlint-cli": "0.27.1",
    "postcss": "8.3.5",
    "prettier": "2.3.1",
    "semantic-release": "17.4.4",
    "serve": "12.0.0",
