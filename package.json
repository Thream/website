    "next": "11.0.1",
    "next-pwa": "5.2.21",
    "next-themes": "0.0.14",
    "next-translate": "1.0.7",
    "react": "17.0.2",
    "react-component-form": "2.0.0",
    "react-dom": "17.0.2",
    "react-responsive": "8.2.0",
    "react-swipeable": "6.1.2",
    "react-textarea-autosize": "8.3.3",
    "universal-cookie": "4.0.4"
