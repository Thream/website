{
  "name": "@thream/website",
  "version": "0.0.1",
  "description": "Thream's website to stay close with your friends and communities.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Thream/website"
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
      "pre-commit": "npm run lint"
    }
  },
  "release-it": {
    "git": {
      "commitMessage": "chore(release): v${version}"
    },
    "github": {
      "release": false
    },
    "npm": {
      "publish": false
    },
    "hooks": {
      "before:init": [
        "npm run lint"
      ]
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular",
        "infile": "CHANGELOG.md"
      }
    }
  },
  "scripts": {
    "dev:custom": "cross-env NODE_ENV=development node server",
    "start:custom": "cross-env NODE_ENV=production node server",
    "dev": "next",
    "start": "next start",
    "build": "next build",
    "export": "next export",
    "lint": "ts-standard | snazzy",
    "format": "ts-standard --fix | snazzy",
    "release": "release-it",
    "postinstall": "node ./scripts/postinstall.js"
  },
  "dependencies": {
    "axios": "0.21.0",
    "classnames": "2.2.6",
    "express": "4.17.1",
    "express-http-to-https": "1.1.4",
    "fontsource-montserrat": "3.1.5",
    "fontsource-roboto": "3.1.5",
    "html-react-parser": "0.14.2",
    "next": "10.0.3",
    "next-pwa": "5.0.0",
    "normalize.css": "8.0.1",
    "react": "17.0.1",
    "react-component-form": "1.2.2",
    "react-dom": "17.0.1",
    "react-infinite-scroll-component": "5.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "11.0.0",
    "@commitlint/config-conventional": "11.0.0",
    "@release-it/conventional-changelog": "2.0.0",
    "@styled-jsx/plugin-sass": "2.0.1",
    "@types/classnames": "2.2.11",
    "@types/node": "14.14.13",
    "@types/react": "17.0.0",
    "@types/styled-jsx": "2.2.8",
    "cross-env": "7.0.3",
    "husky": "4.3.5",
    "release-it": "14.2.2",
    "sass": "1.30.0",
    "snazzy": "9.0.0",
    "ts-standard": "10.0.0",
    "typescript": "4.1.3"
  }
}
