    "@storybook/addon-postcss": "2.0.0",
    "@storybook/react": "6.3.0",
    "@testing-library/jest-dom": "5.14.1",
    "@testing-library/react": "12.0.0",
    "@types/jest": "26.0.23",
    "@types/node": "15.12.4",
    "@types/react": "17.0.11",
    "@types/react-responsive": "8.0.2",
    "@types/styled-jsx": "2.2.8",
