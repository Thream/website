{
  "name": "@thream/website",
  "version": "0.0.1",
  "description": "Thream's website to stay close with your friends and communities.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Thream/website"
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
      "pre-commit": "npm run lint"
    }
  },
  "release-it": {
    "git": {
      "commitMessage": "chore(release): v${version}"
    },
    "github": {
      "release": false
    },
    "npm": {
      "publish": false
    },
    "hooks": {
      "before:init": [
        "npm run lint",
        "npm run build",
        "npm run lighthouse"
      ]
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular",
        "infile": "CHANGELOG.md"
      }
    }
  },
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "build": "next build",
    "export": "next export",
    "lint": "ts-standard | snazzy",
    "format": "ts-standard --fix | snazzy",
    "release": "release-it",
    "lighthouse": "lhci autorun",
    "postinstall": "copy-env-cli"
  },
  "dependencies": {
    "@fontsource/poppins": "4.2.0",
    "@fontsource/roboto": "4.2.0",
    "axios": "0.21.1",
    "classnames": "2.2.6",
    "fastest-validator": "1.10.0",
    "next": "10.0.5",
    "next-pwa": "5.0.5",
    "normalize.css": "8.0.1",
    "react": "17.0.1",
    "react-component-form": "1.3.0",
    "react-dom": "17.0.1",
    "react-infinite-scroll-component": "6.0.0",
    "universal-cookie": "4.0.4"
  },
  "devDependencies": {
    "@commitlint/cli": "11.0.0",
    "@commitlint/config-conventional": "11.0.0",
    "@lhci/cli": "0.7.0",
    "@release-it/conventional-changelog": "2.0.0",
    "@styled-jsx/plugin-sass": "2.0.1",
    "@types/classnames": "2.2.11",
    "@types/node": "14.14.25",
    "@types/react": "17.0.1",
    "@types/styled-jsx": "2.2.8",
    "copy-env-cli": "1.0.0",
    "husky": "4.3.8",
    "release-it": "14.3.0",
    "sass": "1.32.6",
    "snazzy": "9.0.0",
    "ts-standard": "10.0.0",
    "typescript": "4.1.3"
  }
}
